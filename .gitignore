# vigia — root ignores. Module-specific ignores live in each module's own
# .gitignore (e.g. recorder/.gitignore). These patterns match at any depth.

# Dependencies
node_modules/

# Package-manager stores & caches
.pnpm-store/
.npm/

# Build output
dist/
build/
target/        # Java/Spring (future api module)

# Environment & secrets
.env
.env.*
!.env.example

# Logs
*.log
logs/

# Local Claude Code settings (shared .claude/settings.json stays tracked)
.claude/settings.local.json

# OS cruft
.DS_Store
Thumbs.db

# Editor cruft
*.swp
*~
